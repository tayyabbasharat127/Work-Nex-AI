# ─── Required secrets (copy to .env and fill in) ──────────────────────────────

# JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=
JWT_REFRESH_SECRET=

# Email (Gmail App Password — https://myaccount.google.com/apppasswords)
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@worknexai.com

# ─── Public URLs (update for your deployment) ──────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_AI_URL=http://localhost:8000
NEXT_PUBLIC_MULTI_AGENT_API_URL=http://localhost:8010

# ─── AI Provider (pick one) ────────────────────────────────────────────────────
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# ─── Power BI (optional — for /dashboard/admin/powerbi) ───────────────────────
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=
POWERBI_TENANT_ID=
POWERBI_WORKSPACE_ID=
POWERBI_REPORT_ID=
POWERBI_DATASET_ID=
POWERBI_EMBED_URL=

# ─── LangSmith (optional — for multi-agent tracing) ───────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
