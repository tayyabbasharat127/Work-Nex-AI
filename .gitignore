# ============================================
# WorkNex AI - Complete .gitignore
# ============================================

# ─── Node.js & NPM ────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ─── Environment Variables ────────────────────
.env
.env.local
.env.development
.env.test
.env.production
.env.*.local
*.env

# ─── Build Output ─────────────────────────────
dist/
build/
.next/
out/
*.tsbuildinfo

# ─── Python ───────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
*.egg-info/
.eggs/
*.egg
pip-log.txt
pip-delete-this-directory.txt

# ─── Database ─────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.db-journal
prisma/migrations/*_backup/

# ─── Logs ─────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# ─── OS Files ─────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ─── IDE & Editors ────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.sublime-project

# ─── Testing ──────────────────────────────────
coverage/
.nyc_output/
*.lcov
.coverage
htmlcov/
.pytest_cache/
.tox/

# ─── Temporary Files ──────────────────────────
tmp/
temp/
*.tmp
*.bak
*.backup
*~

# ─── Security & Secrets ───────────────────────
*.pem
*.key
*.cert
*.crt
gcp-key.json
service-account.json
secrets.json
credentials.json

# ─── Documentation Artifacts ──────────────────
*.pdf
*.docx
*.xlsx
!docs/**/*.pdf
!docs/**/*.docx

# ─── Cache ────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# ─── Misc ─────────────────────────────────────
.vercel
.turbo
.contentlayer
