DEBUG=false
HOST=0.0.0.0
PORT=8000

# Backend integration
BACKEND_URL=http://localhost:5000/api/v1
# Service-to-service token (generate a long random string, set same in backend BACKEND_SERVICE_TOKEN)
BACKEND_TOKEN=

# ── AI Provider ────────────────────────────────────────────────────────────
# "statistical"  → keyword + BM25 RAG (no API key needed, always works)
# "langchain"    → LangChain agentic AI (requires OPENROUTER_API_KEY below)
AI_PROVIDER=statistical

# ── LLM API Key — OpenRouter (gpt-4o-mini) only ────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── LangChain settings ──────────────────────────────────────────────────────
# Override the model above if needed
LANGCHAIN_MODEL=
# Set to true to print agent thoughts + tool calls in logs
LANGCHAIN_VERBOSE=false
