DEBUG=false
HOST=0.0.0.0
PORT=8000

# Backend integration
BACKEND_URL=http://localhost:5000/api/v1
# Service-to-service token (generate a long random string, set same in backend BACKEND_SERVICE_TOKEN)
BACKEND_TOKEN=

# ── AI Provider ────────────────────────────────────────────────────────────
# "statistical"  → keyword + BM25 RAG (no API key needed, always works)
# "langchain"    → LangChain agentic AI (requires at least one LLM API key below)
AI_PROVIDER=statistical

# ── LLM API Keys (pick one; first non-empty wins) ──────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=

# ── Ollama (local LLM, free, no API key) ───────────────────────────────────
# Run: ollama serve && ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── LangChain settings ──────────────────────────────────────────────────────
# Override default model per provider (e.g. gpt-4o, gemini-1.5-pro, claude-opus-4-8)
LANGCHAIN_MODEL=
# Set to true to print agent thoughts + tool calls in logs
LANGCHAIN_VERBOSE=false
