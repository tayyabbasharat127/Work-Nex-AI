# ============================================
# WorkNex AI Service (Python) - .gitignore
# ============================================

# ─── Python ───────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ─── Virtual Environments ─────────────────────
env/
venv/
ENV/
env.bak/
venv.bak/
.venv/

# ─── Python Package Files ─────────────────────
*.egg-info/
.eggs/
*.egg
dist/
build/
pip-log.txt
pip-delete-this-directory.txt

# ─── Environment Variables ────────────────────
.env
.env.local
.env.development
.env.production
*.env

# ─── Logs ─────────────────────────────────────
*.log
logs/

# ─── Testing ──────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# ─── IDE & Editors ────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.spyderproject
.spyproject
.ropeproject

# ─── OS Files ─────────────────────────────────
.DS_Store
Thumbs.db

# ─── Jupyter Notebook ─────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── MyPy ─────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ─── Temporary Files ──────────────────────────
tmp/
temp/
*.tmp
