            "country": "Pakistan"
          },
          "note": "Creates organization with TRIAL plan"
        },
        {
          "name": "Subscribe to Plan",
          "method": "POST",
          "url": "/billing/subscribe",
          "headers": {
            "Content-Type": "application/json",
            "Authorization": "Bearer {{SUPER_ADMIN_TOKEN}}"
          },
          "body": {
            "organizationId": "{{ORG_ID}}",
            "planType": "STARTER",
            "billingCycle": "MONTHLY",
            "paymentMethod": "credit_card",
            "paymentReference": "ch_1234567890"
          }
        },
        {
          "name": "Upgrade Plan",
          "method": "POST",
          "url": "/billing/upgrade",
          "headers": {
            "Content-Type": "application/json",
            "Authorization": "Bearer {{SUPER_ADMIN_TOKEN}}"
          },
          "body": {
            "organizationId": "{{ORG_ID}}",
            "newPlan": "GROWTH",
            "billingCycle": "ANNUAL"
          }
        },
        {
          "name": "Get Subscription",
          "method": "GET",
          "url": "/billing/{{ORG_ID}}/subscription",
          "headers": {
            "Authorization": "Bearer {{SUPER_ADMIN_TOKEN}}"
          }
        },
        {
          "name": "Get Invoices",
          "method": "GET",
          "url": "/billing/{{ORG_ID}}/invoices",
          "headers": {
            "Authorization": "Bearer {{SUPER_ADMIN_TOKEN}}"
          }
        },
        {
          "name": "Check Employee Limit",
          "method": "GET",
          "url": "/billing/{{ORG_ID}}/employee-limit",
          "headers": {
            "Authorization": "Bearer {{SUPER_ADMIN_TOKEN}}"
          }
        },
        {
          "name": "Cancel Subscription",
          "method": "POST",
          "url": "/billing/{{ORG_ID}}/cancel",
          "headers": {
            "Authorization": "Bearer {{SUPER_ADMIN_TOKEN}}"
          }
        }
      ]
    }
  },

  "testingWorkflow": {
    "step1": "Start backend: cd worknex-backend && npm run dev",
    "step2": "Test health: GET http://localhost:5000/health",
    "step3": "Register user: Use 1_AUTHENTICATION > Register User",
    "step4": "Login: Use 1_AUTHENTICATION > Login (save the accessToken)",
    "step5": "Replace {{TOKEN}} with your accessToken in all requests",
    "step6": "Test each module in order",
    "step7": "For admin endpoints, login with admin credentials first"
  },

  "commonErrors": {
    "401": "Unauthorized - Token missing or invalid",
    "403": "Forbidden - Insufficient permissions (wrong role)",
    "404": "Not Found - Resource doesn't exist",
    "422": "Validation Error - Check request body format",
    "500": "Server Error - Check backend logs"
  }
}
