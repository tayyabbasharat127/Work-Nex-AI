# ============================================
# WorkNex Frontend (Next.js) - .gitignore
# ============================================

# ─── Node.js & Dependencies ───────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ─── Next.js Build Output ─────────────────────
.next/
next/
out/
build/
dist/

# ─── Environment Variables ────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# ─── Logs ─────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Testing ──────────────────────────────────
coverage/
.nyc_output/

# ─── OS Files ─────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db

# ─── IDE & Editors ────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Vercel ───────────────────────────────────
.vercel

# ─── TypeScript ───────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Cache ────────────────────────────────────
.cache/
.eslintcache
