{
  "name": "worknex-ai-workspace",
  "private": true,
  "scripts": {
    "health": "powershell -ExecutionPolicy Bypass -File scripts/health-check.ps1",
    "start:dev": "powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "agents:dev": "cd multi-agent-service && npm.cmd run dev",
    "agents:start": "cd multi-agent-service && npm.cmd run start",
    "agents:memory:setup": "cd multi-agent-service && npm.cmd run memory:setup",
    "smoke": "powershell -ExecutionPolicy Bypass -File scripts/smoke-test.ps1",
    "test:full": "powershell -ExecutionPolicy Bypass -File scripts/full-module-test.ps1",
    "db:validate": "cd worknex-backend && npm.cmd run db:validate",
    "db:setup": "cd worknex-backend && npm.cmd run db:setup",
    "db:status": "cd worknex-backend && npm.cmd run db:status",
    "db:reset": "cd worknex-backend && npm.cmd run db:reset",
    "db:seed": "cd worknex-backend && npm.cmd run db:seed",
    "demo:seed": "npm --prefix worknex-backend run demo:seed",
    "demo:reset": "npm --prefix worknex-backend run demo:reset",
    "demo:validate": "npm --prefix worknex-backend run demo:validate",
    "demo:rebuild": "npm --prefix worknex-backend run demo:rebuild",
    "demo:start": "node scripts/demo-runtime.js start",
    "demo:stop": "node scripts/demo-runtime.js stop",
    "demo:status": "node scripts/demo-runtime.js status",
    "demo:health": "node scripts/demo-runtime.js health",
    "playwright:install": "npm --prefix frontend exec playwright install chromium",
    "test:e2e": "npm --prefix frontend run test:e2e",
    "test:e2e:headed": "npm --prefix frontend run test:e2e:headed",
    "db:preflight": "cd worknex-backend && npm.cmd run db:preflight",
    "lint": "cd frontend && npm.cmd run lint",
    "build": "cd frontend && npm.cmd run build"
  }
}
