# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
TRUST_PROXY=false

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/worknex_ai"

# JWT
JWT_SECRET=replace_with_local_dev_secret
JWT_REFRESH_SECRET=replace_with_local_refresh_secret
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d
JWT_REFRESH_EXPIRES_IN=30d

# 2FA
TWO_FA_APP_NAME=WorkNexAI

# Attendance / network verification
ATTENDANCE_TIMEZONE=Asia/Karachi
ORGANIZATION_TIMEZONE=Asia/Karachi
WIFI_VERIFICATION_ENABLED=false
OFFICE_IP_RANGES=127.0.0.1/32,192.168.1.0/24
LATE_THRESHOLD_HOUR=9
LATE_THRESHOLD_MIN=30
HALF_DAY_HOURS=4

# Email (optional in local demo)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@worknex.ai

# TMS Attendance System Integration (optional)
TMS_API_URL=
TMS_API_KEY=

# AI service
AI_SERVICE_URL=http://localhost:8000

# Power BI (optional; missing values produce setup guidance)
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=
POWERBI_TENANT_ID=
POWERBI_WORKSPACE_ID=
POWERBI_REPORT_ID=
POWERBI_DATASET_ID=
POWERBI_EMBED_URL=

# Optional object storage placeholders
GCS_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=
