# Core service
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
TRUST_PROXY=false
LOG_LEVEL=debug
LOG_TO_FILE=false
METRICS_ENABLED=false
SHUTDOWN_TIMEOUT_MS=30000

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/worknex_ai

# Authentication (use independent, randomly generated values of at least 32 characters)
JWT_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-different-strong-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_ISSUER=worknex-backend
JWT_AUDIENCE=worknex-platform
TWO_FA_CHALLENGE_EXPIRES_IN=5m
TWO_FA_APP_NAME=WorkNexAI
ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key

# Refresh cookie
REFRESH_COOKIE_NAME=refreshToken
REFRESH_COOKIE_MAX_AGE_MS=2592000000
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=

# Explicit one-time platform bootstrap; keep false after provisioning
BOOTSTRAP_SUPER_ADMIN=false
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Rate limits
API_RATE_LIMIT_MAX=2000
AUTH_RATE_LIMIT_MAX=500
BIOMETRIC_WEBHOOK_RATE_LIMIT=120
ICLOCK_RATE_LIMIT_MAX=600

# Email (required in production)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com

# AI service (required in production)
AI_SERVICE_URL=http://localhost:8000
OPENAI_API_KEY=
GROQ_API_KEY=

# Storage: production must use s3
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=storage
S3_BUCKET=
S3_PREFIX=worknex
AWS_REGION=

# Attendance policy
ATTENDANCE_TIMEZONE=Asia/Karachi
WIFI_VERIFICATION_ENABLED=false
OFFICE_IP_RANGES=127.0.0.1/32,192.168.1.0/24
LATE_THRESHOLD_HOUR=9
LATE_THRESHOLD_MIN=30
HALF_DAY_HOURS=4

# Biometric outbound targets (mandatory allowlist in production)
BIOMETRIC_ALLOWED_HOSTS=

# TMS integration (optional)
TMS_MODE=
TMS_API_URL=
TMS_API_KEY=
TMS_API_USER=
TMS_API_PASS=
TMS_TIMEOUT_MS=10000
TMS_RETRY_COUNT=3
TMS_LATE_CUTOFF_H=9
TMS_SFTP_HOST=
TMS_SFTP_PORT=22
TMS_SFTP_USER=
TMS_SFTP_PASS=
TMS_SFTP_PATH=/attendance

# Power BI (optional, but configure the required group together)
POWERBI_TENANT_ID=
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=
POWERBI_WORKSPACE_ID=
POWERBI_REPORT_ID=
POWERBI_DATASET_ID=
POWERBI_EMBED_URL=

# Explicit local test/seed tooling credentials (never use production accounts)
BACKEND_URL=http://localhost:5000
TEST_ADMIN_EMAIL=
TEST_ADMIN_PASSWORD=
TEST_USER_PASSWORD=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_USER_PASSWORD=
