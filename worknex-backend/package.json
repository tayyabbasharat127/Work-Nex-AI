{
  "name": "worknex-backend",
  "version": "1.0.0",
  "description": "WorkNex AI - Workforce Management Backend",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "predev": "prisma validate && prisma migrate deploy",
    "dev": "nodemon src/app.js",
    "migrate": "npx prisma migrate dev",
    "generate": "npx prisma generate",
    "seed": "node prisma/seed.js",
    "setup": "npx prisma migrate dev --name init && npx prisma generate && node prisma/seed.js",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:status": "prisma migrate status",
    "db:deploy": "prisma migrate deploy",
    "db:dev": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:setup": "prisma validate && prisma generate && prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "demo:seed": "node scripts/demo-seeder.js seed",
    "demo:reset": "node scripts/demo-seeder.js reset",
    "demo:validate": "node scripts/demo-seeder.js validate",
    "demo:rebuild": "prisma validate && prisma migrate deploy && node scripts/demo-seeder.js rebuild",
    "db:preflight": "node scripts/db-preflight.js",
    "worker:scheduled": "node src/workers/scheduled.worker.js",
    "worker:tms-sync": "node src/workers/scheduled.worker.js tms-sync",
    "worker:leave-reset": "node src/workers/scheduled.worker.js leave-balance-reset",
    "worker:absences": "node src/workers/scheduled.worker.js generate-absences",
    "worker:etl-nightly": "node src/workers/scheduled.worker.js etl-nightly",
    "worker:etl-monthly": "node src/workers/scheduled.worker.js etl-monthly",
    "worker:alerts": "node src/workers/scheduled.worker.js scan-alerts",
    "worker:auth-cleanup": "node src/workers/scheduled.worker.js cleanup-auth-tokens",
    "leave:backfill-defaults": "node scripts/backfill-default-leave-policies.js",
    "policy:configure": "node scripts/configure-nts-faculty-policy.js",
    "lint": "eslint src scripts prisma --max-warnings=0",
    "test": "jest --testPathPatterns=src/__tests__",
    "test:watch": "jest --testPathPatterns=src/__tests__ --watch"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@prisma/client": "^5.10.0",
    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^12.7.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.22.6",
    "nodemailer": "^9.0.3",
    "otplib": "^12.0.1",
    "pg": "^8.11.3",
    "qrcode": "^1.5.3",
    "uuid": "^11.1.1",
    "winston": "^3.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prisma": "^5.10.0"
  }
}
