{
  "name": "worknex-backend",
  "version": "1.0.0",
  "description": "WorkNex AI - Workforce Management Backend",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "migrate": "npx prisma migrate dev",
    "generate": "npx prisma generate",
    "seed": "node prisma/seed.js",
    "setup": "npx prisma migrate dev --name init && npx prisma generate && node prisma/seed.js",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:status": "prisma migrate status",
    "db:deploy": "prisma migrate deploy",
    "db:dev": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:setup": "prisma validate && prisma generate && prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "db:preflight": "node scripts/db-preflight.js",
    "leave:backfill-defaults": "node scripts/backfill-default-leave-policies.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.12",
    "otplib": "^12.0.1",
    "pg": "^8.11.3",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.1",
    "winston": "^3.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.10.0"
  }
}
