generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  users          User[]
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, name])
  @@unique([id, organizationId])
  @@index([organizationId])
}

model User {
  id             String              @id @default(uuid())
  organizationId String
  employeeId     String              @unique
  firstName      String
  lastName       String
  email          String              @unique
  passwordHash   String
  roleId         String
  departmentId   String?
  managerId      String?
  designation    String?
  joiningDate    DateTime?
  isActive       Boolean             @default(true)
  twoFAEnabled   Boolean             @default(false)
  twoFASecret    String?
  profilePicture String?
  phone          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  attendance       Attendance[]
  auditLogs        AuditLog[]
  leaveBalances    LeaveBalance[]
  approvedLeaves   LeaveRequest[]      @relation("ApproverLeaves")
  leaveRequests    LeaveRequest[]      @relation("EmployeeLeaves")
  notifications    Notification[]
  performance      PerformanceRecord[]
  attritionRecords AttritionRecord[]
  refreshTokens    RefreshToken[]
  uploadedPolicyDocuments PolicyDocument[] @relation("UploadedPolicyDocuments")
  approvedPolicyVersions LeavePolicyVersion[] @relation("ApprovedPolicyVersions")
  employeeLeaveDecisionLogs LeaveDecisionLog[] @relation("EmployeeLeaveDecisionLogs")
  evaluatedLeaveDecisionLogs LeaveDecisionLog[] @relation("EvaluatorLeaveDecisionLogs")
  department     Department?         @relation(fields: [departmentId, organizationId], references: [id, organizationId])
  manager        User?               @relation("ManagerSubordinates", fields: [managerId, organizationId], references: [id, organizationId])
  organization   Organization        @relation(fields: [organizationId], references: [id])
  subordinates   User[]              @relation("ManagerSubordinates")
  customRole     Role                @relation(fields: [roleId], references: [id])

  @@index([organizationId])
  @@unique([id, organizationId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LeavePolicy {
  id              String         @id @default(uuid())
  organizationId  String
  leaveType       LeaveType
  totalDays       Int
  carryForward    Boolean        @default(false)
  maxCarryForward Int            @default(0)
  applicableRoleIds String[]     @default([])
  description     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  leaveBalances   LeaveBalance[]
  organization    Organization   @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, leaveType])
  @@unique([id, organizationId])
  @@index([organizationId, leaveType])
}

model LeaveBalance {
  id            String      @id @default(uuid())
  organizationId String
  userId        String
  policyId      String
  year          Int
  totalDays     Int
  usedDays      Int         @default(0)
  remainingDays Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  policy        LeavePolicy @relation(fields: [policyId, organizationId], references: [id, organizationId])
  user          User        @relation(fields: [userId, organizationId], references: [id, organizationId], onDelete: Cascade)
  organization  Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, policyId, year])
  @@index([organizationId])
}

model LeaveRequest {
  id           String      @id @default(uuid())
  organizationId String
  employeeId   String
  approverId   String?
  leaveType    LeaveType
  startDate    DateTime
  endDate      DateTime
  totalDays    Int
  reason       String
  status       LeaveStatus @default(PENDING)
  approverNote String?
  appliedAt    DateTime    @default(now())
  reviewedAt   DateTime?
  updatedAt    DateTime    @updatedAt
  isSandwiched      Boolean @default(false)
  sandwichExtraDays Int     @default(0)
  approver     User?       @relation("ApproverLeaves", fields: [approverId, organizationId], references: [id, organizationId])
  employee     User        @relation("EmployeeLeaves", fields: [employeeId, organizationId], references: [id, organizationId])
  organization Organization @relation(fields: [organizationId], references: [id])
  decisionLogs LeaveDecisionLog[]

  @@index([organizationId, status])
  @@unique([id, organizationId])
}

model Attendance {
  id           String           @id @default(uuid())
  organizationId String
  userId       String
  date         DateTime         @db.Date
  checkIn      DateTime?
  checkOut     DateTime?
  status       AttendanceStatus @default(PRESENT)
  workingHours Float?
  source       String           @default("MANUAL")
  latitude     Float?
  longitude    Float?
  ipAddress    String?
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  user         User             @relation(fields: [userId, organizationId], references: [id, organizationId], onDelete: Cascade)
  organization Organization     @relation(fields: [organizationId], references: [id])

  @@unique([userId, date])
  @@index([organizationId, date])
  @@index([ipAddress])
}

model Holiday {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  date           DateTime     @db.Date
  description    String?
  isRecurring    Boolean      @default(false)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model Notification {
  id        String           @id @default(uuid())
  organizationId String
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization  @relation(fields: [organizationId], references: [id])

  @@index([organizationId, userId, isRead])
}

enum BiometricIntegrationType {
  DATABASE
  API
  ADMS
}

// Per-organization config for connecting an attendance sync source (currently
// ZKTeco/BioTime). Feeds tms.provider.js, which today reads this from env
// vars — this table replaces that with an admin-editable, per-org config.
// All credential fields are stored encrypted (see utils/encryption.js) and
// are never returned to the frontend once saved.
model BiometricIntegration {
  id                       String                    @id @default(uuid())
  organizationId           String                    @unique
  integrationType          BiometricIntegrationType  @default(DATABASE)
  enabled                  Boolean                   @default(false)

  dbType                   String?
  dbHost                   String?
  dbPort                   Int?
  dbName                   String?
  dbUsername               String?
  dbPasswordEncrypted      String?
  dbTableName              String?

  apiBaseUrl               String?
  apiKeyEncrypted          String?

  admsCommunicationKeyEncrypted String?

  fieldMapping             Json                      @default("{}")
  syncIntervalMinutes      Int                       @default(60)

  lastTestedAt             DateTime?
  lastTestResult           Json?

  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt

  organization             Organization              @relation(fields: [organizationId], references: [id])
  devices                  BiometricDevice[]
}

enum BiometricDeviceStatus {
  ONLINE
  OFFLINE
  UNKNOWN
}

model BiometricDevice {
  id                     String                @id @default(uuid())
  organizationId         String
  biometricIntegrationId String?
  name                   String
  deviceSerial           String?
  hmacSecretEncrypted    String?
  ipAddress              String?
  port                   Int?
  location               String?
  status                 BiometricDeviceStatus @default(UNKNOWN)
  lastSeenAt             DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  organization           Organization          @relation(fields: [organizationId], references: [id])
  integration             BiometricIntegration? @relation(fields: [biometricIntegrationId], references: [id], onDelete: SetNull)
  webhookNonces           BiometricWebhookNonce[]

  @@index([organizationId])
  @@unique([deviceSerial])
}

model BiometricWebhookNonce {
  id        String   @id @default(uuid())
  deviceId  String
  nonce     String
  expiresAt DateTime
  createdAt DateTime @default(now())
  device    BiometricDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, nonce])
  @@index([expiresAt])
}

model PerformanceRecord {
  id                String   @id @default(uuid())
  organizationId    String
  userId            String
  month             Int
  year              Int
  presentDays       Int      @default(0)
  absentDays        Int      @default(0)
  lateDays          Int      @default(0)
  leaveDays         Int      @default(0)
  avgWorkingHours   Float    @default(0)
  attendanceScore   Float    @default(0)
  leaveScore        Float    @default(0)
  punctualityScore  Float    @default(0)
  overallScore      Float    @default(0)
  mlPredictedScore  Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId, organizationId], references: [id, organizationId], onDelete: Cascade)
  organization      Organization @relation(fields: [organizationId], references: [id])
  attritionRecords  AttritionRecord[]

  @@unique([userId, month, year])
  @@unique([id, organizationId])
  @@index([organizationId, year, month])
}

model AttritionRecord {
  id                  String            @id @default(uuid())
  organizationId      String
  userId              String
  month               Int
  year                Int
  riskScore           Float
  riskLabel           String
  willLeaveProb       Float             @default(0)
  factors             Json              @default("[]")
  modelVersion        String            @default("deterministic-v1")
  source              String            @default("DETERMINISTIC")
  performanceRecordId String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  user                User              @relation(fields: [userId, organizationId], references: [id, organizationId], onDelete: Cascade)
  organization        Organization      @relation(fields: [organizationId], references: [id])
  performanceRecord   PerformanceRecord? @relation(fields: [performanceRecordId, organizationId], references: [id, organizationId], onDelete: NoAction)

  @@unique([userId, month, year])
  @@index([organizationId, year, month])
  @@index([organizationId, riskLabel])
}

model EtlSyncLog {
  id          String    @id @default(uuid())
  organizationId String?
  source      String
  status      String
  recordsIn   Int       @default(0)
  recordsOut  Int       @default(0)
  errorLog    String?
  startedAt   DateTime
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model Organization {
  id           String        @id @default(uuid())
  name         String
  slug         String        @unique
  industry     String?
  country      String        @default("Pakistan")
  logoUrl      String?
  address      String?
  website      String?
  phone        String?
  ownerId      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  invoices     Invoice[]
  users        User[]
  departments  Department[]
  attendance   Attendance[]
  leavePolicies LeavePolicy[]
  leaveBalances LeaveBalance[]
  leaveRequests LeaveRequest[]
  notifications Notification[]
  performanceRecords PerformanceRecord[]
  attritionRecords   AttritionRecord[]
  holidays     Holiday[]
  auditLogs    AuditLog[]
  etlSyncLogs  EtlSyncLog[]
  settings     OrganizationSettings?
  policyDocuments PolicyDocument[]
  extractedPolicyRules ExtractedPolicyRule[]
  leavePolicyVersions LeavePolicyVersion[]
  leaveDecisionLogs LeaveDecisionLog[]
  subscription Subscription?
  customRoles  Role[]
  biometricIntegration BiometricIntegration?
  biometricDevices     BiometricDevice[]
}

model OrganizationSettings {
  id                      String       @id @default(uuid())
  organizationId          String       @unique
  timezone                String       @default("Asia/Karachi")
  workingHoursStart       String       @default("09:00")
  workingHoursEnd         String       @default("17:00")
  lateThresholdMinutes    Int          @default(30)
  officeIpRanges          Json?
  wifiVerificationEnabled Boolean      @default(false)
  leaveAutomationEnabled  Boolean      @default(true)
  sandwichLeaveEnabled    Boolean      @default(false)
  attendancePolicyJson    Json?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model PolicyDocument {
  id             String               @id @default(uuid())
  organizationId String
  uploadedById   String
  fileName       String
  fileType       String
  filePath       String?
  extractedText  String?
  status         PolicyDocumentStatus @default(UPLOADED)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy     User                 @relation("UploadedPolicyDocuments", fields: [uploadedById], references: [id])
  extractedRules ExtractedPolicyRule[]
  policyVersions LeavePolicyVersion[]

  @@index([organizationId])
  @@index([organizationId, status])
}

model ExtractedPolicyRule {
  id               String                    @id @default(uuid())
  organizationId   String
  policyDocumentId String
  leaveType        LeaveType
  extractedJson    Json
  confidenceScore  Float                     @default(0)
  status           ExtractedPolicyRuleStatus @default(DRAFT)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  organization     Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  policyDocument   PolicyDocument            @relation(fields: [policyDocumentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, status])
}

model LeavePolicyVersion {
  id               String                   @id @default(uuid())
  organizationId   String
  policyDocumentId String?
  version          Int
  status           LeavePolicyVersionStatus @default(DRAFT)
  effectiveFrom    DateTime
  effectiveTo      DateTime?
  rulesJson        Json
  approvedById     String?
  approvedAt       DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  organization     Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  policyDocument   PolicyDocument?          @relation(fields: [policyDocumentId], references: [id], onDelete: SetNull)
  approvedBy       User?                    @relation("ApprovedPolicyVersions", fields: [approvedById], references: [id], onDelete: SetNull)
  decisionLogs     LeaveDecisionLog[]

  @@unique([organizationId, version])
  @@index([organizationId])
  @@index([organizationId, status])
}

model LeaveDecisionLog {
  id                String              @id @default(uuid())
  organizationId    String
  leaveRequestId    String
  employeeId        String
  decision          String
  confidence        Float               @default(0)
  reasons           Json
  requiredApprovals Json
  policyVersionId   String?
  evaluatedBy       String?
  createdAt         DateTime            @default(now())
  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leaveRequest      LeaveRequest        @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  employee          User                @relation("EmployeeLeaveDecisionLogs", fields: [employeeId], references: [id])
  evaluator         User?               @relation("EvaluatorLeaveDecisionLogs", fields: [evaluatedBy], references: [id], onDelete: SetNull)
  policyVersion     LeavePolicyVersion? @relation(fields: [policyVersionId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, leaveRequestId])
}

model Subscription {
  id                 String             @id @default(uuid())
  organizationId     String             @unique
  plan               PlanType           @default(TRIAL)
  status             SubscriptionStatus @default(TRIAL)
  billingCycle       BillingCycle       @default(MONTHLY)
  maxEmployees       Int                @default(25)
  pricePerMonth      Float
  discountPercent    Float              @default(0)
  trialEndsAt        DateTime?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  licenseKey         String             @unique
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  invoices           Invoice[]
  organization       Organization       @relation(fields: [organizationId], references: [id])
}

model Invoice {
  id               String        @id @default(uuid())
  organizationId   String
  subscriptionId   String?
  invoiceNumber    String        @unique
  plan             PlanType
  billingCycle     BillingCycle
  amount           Float
  discount         Float         @default(0)
  tax              Float         @default(0)
  totalAmount      Float
  status           PaymentStatus @default(PENDING)
  paymentMethod    String?
  paymentReference String?
  paidAt           DateTime?
  dueDate          DateTime
  periodStart      DateTime
  periodEnd        DateTime
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  organization     Organization  @relation(fields: [organizationId], references: [id])
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id])
}

model AuditLog {
  id        String      @id @default(uuid())
  organizationId String?
  userId    String?
  action    AuditAction
  entity    String
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

enum RoleTier {
  SUPER_ADMIN
  ADMIN
  MANAGER
  EMPLOYEE
}

// Dynamic, admin-configurable role. Every row inherits its access-scope
// behavior (self/subordinates/org) from `tier`, but has its own display
// name and capability list, so orgs can define custom roles (e.g. "Dean")
// without needing new scoping logic.
model Role {
  id             String        @id @default(uuid())
  organizationId String?
  name           String
  tier           RoleTier
  permissions    String[]      @default([])
  isSystem       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id])
  users          User[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveType {
  ANNUAL
  SICK
  CASUAL
  MATERNITY
  PATERNITY
  UNPAID
  BEREAVEMENT
  MARRIAGE
  STUDY
  HAJJ
  COMPENSATORY
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
  HOLIDAY
}

enum NotificationType {
  LEAVE_APPLIED
  LEAVE_APPROVED
  LEAVE_REJECTED
  ATTENDANCE_ALERT
  SYSTEM
  REMINDER
}

enum AuditAction {
  READ
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
}

enum PlanType {
  TRIAL
  STARTER
  GROWTH
  BUSINESS
  ENTERPRISE
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  EXPIRED
  CANCELLED
  SUSPENDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PolicyDocumentStatus {
  UPLOADED
  EXTRACTED
  PARSED
  APPROVED
  REJECTED
}

enum ExtractedPolicyRuleStatus {
  DRAFT
  APPROVED
  REJECTED
}

enum LeavePolicyVersionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}
